#!/usr/bin/env bash
script_dir=$(cd $(dirname "${BASH_SOURCE[0]}") && pwd)
dry="0"
platform=""

while [[ $# > 0 ]]; do
	if [[ $1 == "--dry" ]]; then
		dry="1"
	elif [[ $1 == "--platform" ]]; then
		shift
		platform="$1"
	fi
	shift
done

if [[ "$platform" != "mac" && "$platform" != "linux" ]]; then
	echo "Error: --platform is required and must be 'mac' or 'linux'" >&2
	exit 1
fi

export PLATFORM="$platform"

log() {
	if [[ $dry == "1" ]]; then
	    	echo "[DRY RUN]: $@"
	else
		echo "$@"
	fi
}

execute() {
	log "execute: $@"
	if [[ $dry == "1" ]]; then
		return
	fi
	"$@"
}

# Copy the subdirectories in the dir
copy_dir() {
	pushd $1
	to=$2
	dirs=$(find . -maxdepth 1 -mindepth 1 -type d)
	for dir in $dirs; do
		execute rm -rf $to/$dir
		execute cp -r $dir $to/$dir
	done
	popd
}
# Copy a directory and its contents
copy_all_dir() {
	src=$1
	dest=$2
	
	execute mkdir -p $dest
	execute cp -R $src/. $dest/
}

copy_file() {
	from=$1
	to=$2
	name=$(basename $from)
	execute rm $to/$name
	execute cp $from $to/$name
}

log "--------------------dev-env--------------------"

copy_dir .config ~/.config
copy_all_dir .claude ~/.claude
copy_dir .local ~/.local
copy_file .ready-tmux ~
copy_file .config/tmux/.tmux.conf ~
execute env/zshrc
