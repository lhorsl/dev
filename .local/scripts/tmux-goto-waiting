#!/usr/bin/env bash
# Jumps the current client to the first agent window needing attention across ALL
# sessions: prefers @agent_status=waiting (blocked on permission), falls back to
# done. 
set -euo pipefail

pick() {
	tmux list-windows -a -F '#{@agent_status} #{session_name}:#{window_index}' 2>/dev/null \
		| awk -v want="$1" '$1 == want { print $2; exit }'
}

target="$(pick waiting)"
[[ -z "$target" ]] && target="$(pick done)"
[[ -z "$target" ]] && { tmux display-message "no agents waiting"; exit 0; }

tmux switch-client -t "${target%%:*}"
tmux select-window -t "$target"
