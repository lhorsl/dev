{
  "model": "opus[1m]",
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {},
  "skipWorkflowUsageWarning": true,
  "hooks": {
    "UserPromptSubmit": [
      { "hooks": [{ "type": "command", "command": "agent-signal working" }] }
    ],
    "Notification": [
      { "hooks": [{ "type": "command", "command": "agent-signal notification" }] }
    ],
    "Stop": [
      { "hooks": [{ "type": "command", "command": "agent-signal done" }] }
    ]
  }
}
